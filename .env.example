ANTHROPIC_API_KEY=

# Brain host for hook connections.
# Set to Docker container hostname or IP when the brain runs in a container
# and the hook runs on the host machine (e.g. host.docker.internal).
# Defaults to localhost for single-machine setups.
CYRUS_BRAIN_HOST=localhost

# Headless mode — set to 1 to disable all Windows GUI libraries (comtypes,
# pyautogui, pygetwindow, pyperclip, uiautomation). Required for Docker /
# Linux deployments. The companion extension provides session discovery and
# text submission via TCP on port 8770 when this is enabled.
CYRUS_HEADLESS=0

# barf configuration
ISSUE_PROVIDER=local
PLAN_MODEL=claude-opus-4-6
BUILD_MODEL=claude-sonnet-4-6
CONTEXT_USAGE_PERCENT=75

ISSUES_DIR=issues
PLAN_DIR=plans
MAX_AUTO_SPLITS=3
MAX_ITERATIONS=2
MAX_VERIFY_RETRIES=3
CLAUDE_TIMEOUT=3600
FIX_COMMANDS=uv run --project cyrus2 ruff format cyrus2/
AUDIT_MODEL=gpt-4o
TRIAGE_MODEL=claude-haiku-4-5-20251001
SPLIT_MODEL=claude-sonnet-4-6
AUDIT_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
ANTHROPIC_API_KEY=
CLAUDE_AUDIT_MODEL=claude-sonnet-4-6
EXTENDED_CONTEXT_MODEL=claude-opus-4-6
PUSH_STRATEGY=iteration
GITHUB_REPO=
DISABLE_LOG_STREAM=false
BARF_DIR=.barf
PROMPT_DIR=prompts
LOG_FILE=.barf/barf.jsonl
LOG_LEVEL=debug
LOG_PRETTY=true

BUILD_COMMAND=uv run --project cyrus2 ruff check cyrus2/
CHECK_COMMAND=uv run --project cyrus2 ruff format --check cyrus2/
TEST_COMMAND=uv run --project cyrus2 pytest cyrus2/tests/

